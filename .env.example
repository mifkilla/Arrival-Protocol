# ARRIVAL Protocol -- Environment Configuration
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control!

# OpenRouter API key (required for most experiments)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Gonka decentralized inference (optional, for Phase 16)
GONKA_PRIVATE_KEY=your-gonka-private-key-here
GONKA_BASE_URL=https://api.gonka.network/v1

# Optional: override backend for Phase 16
# PHASE16_BACKEND=openrouter  # or "gonka"
